# ── Auth ──────────────────────────────────────────────
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-in-production

# ── InfluxDB ──────────────────────────────────────────
# URL deiner InfluxDB-Instanz (lokal oder Cloud)
INFLUX_URL=http://localhost:8086

# API-Token (in InfluxDB UI unter Data > API Tokens generieren)
INFLUX_TOKEN=your-influxdb-api-token-here

# Organisation (in InfluxDB UI beim Setup festgelegt)
INFLUX_ORG=maggie

# Bucket (in InfluxDB UI unter Data > Buckets erstellen)
INFLUX_BUCKET=telemetry

# ── OBC UDP-Interface (REXUS-Protokoll) ───────────────
# Port, auf dem der Server binäre OBC-Pakete empfängt
# OBC sendet UDP-Pakete (64 Bytes, Big-Endian) an diesen Port
UDP_HOST=0.0.0.0
UDP_PORT=9000
# Socket-Timeout in Sekunden (interne Einstellung)
UDP_TIMEOUT=2.0
