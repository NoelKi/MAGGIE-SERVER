# ── Auth ──────────────────────────────────────────────
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-in-production

# ── InfluxDB ──────────────────────────────────────────
# Docker Image: influxdb
# Starten: docker start influxdb
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-api-token-here
INFLUX_ORG=MAGGIE
INFLUX_BUCKET=MAGGIE_DB

# ── PostgreSQL ────────────────────────────────────────
# Docker Image: postgres
# Starten: docker start postgres
POSTGRES_USER=maggie
POSTGRES_PASSWORD=maggie_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=maggie_users

# ── OBC UDP-Interface (REXUS-Protokoll) ───────────────
# Port, auf dem der Server binäre OBC-Pakete empfängt
# OBC sendet UDP-Pakete (64 Bytes, Big-Endian) an diesen Port
UDP_HOST=0.0.0.0
UDP_PORT=9000
UDP_TIMEOUT=2.0